# =============================================================================
# Agent Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Provider Keys ---
# At least one LLM provider is required for the agent to function

# Google AI (used by default model config)
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_AI_API_KEY=

# OpenAI (used for embeddings and LLM)
OPENAI_API_KEY=
LLM_API_KEY=
EMBEDDING_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenRouter (multi-provider gateway)
OPENROUTER_API_KEY=

# Other LLM providers (optional)
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
DEEPINFRA_API_KEY=
ELEVENLABS_API_KEY=
ZHIPU_API_KEY=
Z_AI_API_KEY=
Z_AI_BASE_URL=

# --- Gateway Channels ---
# At least one channel must be configured for the gateway to start.
# See docs/channels/*.md for setup guides.

# Slack Bot (requires all 3 tokens)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
# SLACK_ENABLED=true
# SLACK_RESPOND_ALL=false
# SLACK_ALLOW_FROM=U01ABC123,U02DEF456

# Telegram Bot
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ENABLED=true
# TELEGRAM_RESPOND_ALL=false
# TELEGRAM_ALLOW_FROM=username1,123456789
# TELEGRAM_HANDLE_EDITS=false
# TELEGRAM_DROP_PENDING=true

# Discord Bot
# DISCORD_BOT_TOKEN=
# DISCORD_ENABLED=true
# DISCORD_APPLICATION_ID=
# DISCORD_GUILD_ID=
# DISCORD_RESPOND_ALL=false
# DISCORD_ALLOW_FROM=username1,123456789

# WhatsApp (Baileys — QR code auth, no token needed)
# WHATSAPP_ENABLED=true
# WHATSAPP_SESSION_PATH=.agent/whatsapp-session
# WHATSAPP_RESPOND_ALL=false
# WHATSAPP_ALLOW_FROM=+1234567890,+0987654321

# Signal (via signal-cli REST API)
# SIGNAL_API_URL=http://localhost:8080
# SIGNAL_PHONE_NUMBER=+1234567890
# SIGNAL_ENABLED=true
# SIGNAL_RESPOND_ALL=false
# SIGNAL_ALLOW_FROM=+1111111111,+2222222222

# Google Chat (webhook-based, requires service account)
# GOOGLE_CHAT_CREDENTIALS=/path/to/service-account-key.json
# GOOGLE_CHAT_PROJECT_ID=your-project-id
# GOOGLE_CHAT_ENABLED=true
# GOOGLE_CHAT_RESPOND_ALL=false

# iMessage (via BlueBubbles REST API on macOS)
# IMESSAGE_API_URL=http://localhost:1234
# IMESSAGE_API_PASSWORD=
# IMESSAGE_ENABLED=true
# IMESSAGE_RESPOND_ALL=false
# IMESSAGE_ALLOW_FROM=+1234567890,user@icloud.com

# --- Search & Tools ---
FIRECRAWL_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
READWISE_API_KEY=

# --- External Services ---
E2B_API_KEY=
LLAMA_CLOUD_API_KEY=
REF_API_KEY=
NOTION_TOKEN=

# Internal integration token for authenticating internal API calls between
# services (e.g., gateway → agent). Generate with: openssl rand -hex 32
INTERNAL_INTEGRATION_TOKEN=

# --- Inngest (workflow engine) ---
INNGEST_DEV=true
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Storage ---
STORAGE_MODE=privacy

# --- Docker Overrides ---
# These are typically set in docker-compose.yml, not here
# MASTRA_SERVER_HOST=0.0.0.0
# MASTRA_SERVER_PORT=4111
